# prisma/schema.prisma's datasource provider is "postgresql" — this must be
# a Postgres connection string everywhere the app runs, local or deployed.
#
# Local development: point at a local Postgres install, or a free Neon
# "dev" branch (Neon lets you branch a database like a git branch — create
# one from your production project so local dev never touches prod data).
#   DATABASE_URL="postgresql://user:password@localhost:5432/prahari_x?schema=public"
#
# Production (Neon): use the POOLED connection string (the one with
# "-pooler" in the hostname) from your Neon project's Connection Details
# panel — required because serverless/edge platforms like Render open many
# short-lived connections, and only the pooled endpoint handles that safely.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/prahari_x?sslmode=require"

JWT_ACCESS_SECRET="replace-with-a-long-random-string"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"
JWT_ACCESS_TTL="15m"
# Refresh token lifetime when the user checks "Remember me" at login.
JWT_REFRESH_TTL="30d"
# Refresh token lifetime for a normal (non-"remember me") session.
JWT_REFRESH_TTL_SHORT="1d"

PORT=4000
# One origin, or a comma-separated list (production domain + any Vercel
# preview URLs you want to allow), e.g.:
#   CLIENT_ORIGIN="https://prahari-x.vercel.app,http://localhost:5173"
CLIENT_ORIGIN="http://localhost:5173"

# --- Email (registration verification + password reset OTP) ---
# Leave SMTP_HOST unset (or blank) to use the console-log fallback: every
# verification link and OTP code is printed straight to this terminal, so
# register -> verify and forgot-password -> reset are fully testable with
# zero setup. The server prints which mode is active on startup — check
# there first if you're not seeing the expected emails/logs.
# Fill these in with a real provider (SendGrid, SES, Mailgun, Gmail app
# password, etc.) to switch to sending real email — no code changes needed,
# the very next email sent will go out for real instead of being logged.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="apikey"
# SMTP_PASS="replace-with-your-smtp-password"
# SMTP_FROM="PRAHARI X <no-reply@your-domain.com>"
