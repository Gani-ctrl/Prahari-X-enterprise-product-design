# Set to "false" to talk to the real Express + Prisma API in /server
# instead of the in-browser mock. Restart `npm run dev` after changing this.
# Defaults to false — the platform is meant to run against the real
# database so every module stays in sync. Only set to "true" for offline
# UI work with the backend stopped.
VITE_USE_MOCK_API=false

# Where the real API lives. Left as "/api" by default so the Vite dev
# server's proxy (see vite.config.ts) forwards requests to
# http://localhost:4000 with zero CORS setup.
#
# Production (Vercel): the frontend and backend are on different origins
# (Vercel + Render), so this must be the FULL backend URL, including
# "/api", e.g.:
#   VITE_API_BASE_URL=https://prahari-x-api.onrender.com/api
# Set this in the Vercel project's Environment Variables settings — it's
# baked in at build time (Vite only exposes VITE_* vars at build time, not
# runtime), so changing it requires a redeploy.
VITE_API_BASE_URL=/api
